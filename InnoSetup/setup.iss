[Code]
// ЙщГч Windows API
function TerminateProcess(hProcess: THandle; uExitCode: UINT): BOOL;
external 'TerminateProcess@kernel32.dll stdcall';
function OpenProcess(dwDesiredAccess: DWORD; bInheritHandle: BOOL; dwProcessId: DWORD): THandle;
external 'OpenProcess@kernel32.dll stdcall';
function CloseHandle(hObject: THandle): BOOL;
external 'CloseHandle@kernel32.dll stdcall';

const
  PROCESS_TERMINATE = $0001;

// әмІйҢшіМКЗ·сөжФЪ
function IsProcessRunning(const ExeName: string): Boolean;
var
  WMIC, WbemScriptor, ProcessList: Variant;
begin
  Result := False;
  try
    WMIC := CreateOleObject('WbemScripting.SWbemLocator');
    WbemScriptor := WMIC.ConnectServer('localhost', 'root\CIMV2');
    ProcessList := WbemScriptor.ExecQuery(
      Format('SELECT * FROM Win32_Process WHERE Name="%s"', [ExeName])
    );
    Result := (ProcessList.Count > 0);
  except
    Result := False;
  end;
end;

// ЦХЦ№ҢшіМ
procedure KillProcessSilently(const ExeName: string);
var
  WMIC, WbemScriptor, ProcessList, Process: Variant;
  i: Integer;
  ProcessHandle: THandle;
  Success: Boolean;
begin
  Success := True;
  try
    WMIC := CreateOleObject('WbemScripting.SWbemLocator');
    WbemScriptor := WMIC.ConnectServer('localhost', 'root\CIMV2');
    ProcessList := WbemScriptor.ExecQuery(
      Format('SELECT * FROM Win32_Process WHERE Name="%s"', [ExeName])
    );
    
    for i := 0 to ProcessList.Count - 1 do
    begin
      Process := ProcessList.ItemIndex(i);
      ProcessHandle := OpenProcess(PROCESS_TERMINATE, False, Process.ProcessID);
      if ProcessHandle <> 0 then
      begin
        if not TerminateProcess(ProcessHandle, 0) then
          Success := False;
        CloseHandle(ProcessHandle);
      end
      else
        Success := False;
    end;
  except
    Success := False;
  end;

  if not Success then
    MsgBox(Format('ОЮ·ЁЦХЦ№ҢшіМ %sӘ¬ЗлКЦ¶Ү№Ш±ХғуЦШКФҰӘ', [ExeName]), mbError, MB_OK);
end;

// °ІЧ°З°әмІй
function InitializeSetup(): Boolean;
begin
  // әмІйіМРтКЗ·сХэФЪФЛРРӘ¬Из№ыКЗФтіұКФЦХЦ№
  if IsProcessRunning('{#MyAppExeName}') then
  begin
    if MsgBox('MastercardHost ХэФЪФЛРРӘ¬РиТҒ№Ш±ХғуІЕДЬәМРш°ІЧ°ҰӘКЗ·сБұәө№Ш±ХӘү', mbConfirmation, MB_YESNO) = IDYES then
    begin
      KillProcessSilently('{#MyAppExeName}');
      // µИөэҢшіМҢбКш
      Sleep(1000);
    end
    else
    begin
      MsgBox('°ІЧ°ОЮ·ЁәМРшӘ¬ЗлКЦ¶Ү№Ш±Х MastercardHost ғуЦШРВФЛРР°ІЧ°іМРтҰӘ', mbError, MB_OK);
      Result := False;
      Exit;
    end;
  end;
  
  Result := True;
end;

// Р¶ФШК±ңІД¬ө¦Ан
procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);
begin
  if CurUninstallStep = usUninstall then
  begin
    // ңІД¬ЦХЦ№ҢшіМӘЁОЮИ·ИП¶Ф»°үтӘ©
    if IsProcessRunning('{#MyAppExeName}') then
    begin
      KillProcessSilently('{#MyAppExeName}');
      // µИөэҢшіМҢбКш
      Sleep(1000);
    end;

    // ЗүЦЖЙңіэДүВә
    DelTree(ExpandConstant('{app}'), True, True, True);
  end;
end;

